{
  "name": "chatllm",
  "displayName": "Chatllm",
  "description": "Chatllm integration for the bundled VS Code workspace.",
  "version": "0.3.0",
  "publisher": "chatllm",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["AI", "Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "scripts": {
    "build": "node esbuild.mjs"
  },
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "configuration": {
      "title": "Chatllm",
      "properties": {
        "chatllm.modelSelection": {
          "type": "string",
          "enum": ["auto", "manual"],
          "default": "manual",
          "description": "Local override for model selection mode. When 'auto', the backend may upgrade the model based on the request. Configure models in the Chatllm app."
        },
        "chatllm.chatMode": {
          "type": "string",
          "enum": ["normal", "agent"],
          "default": "normal",
          "description": "Local default chat mode for new chats. Can be overridden per chat."
        },
        "chatllm.useRag": {
          "type": "boolean",
          "default": false,
          "description": "Local default for RAG on new chats. Can be overridden per chat."
        },
        "chatllm.toolsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Local default for tool calling on new chats. Can be overridden per chat."
        },
        "chatllm.systemPrompt": {
          "type": "string",
          "default": "",
          "description": "Optional local system prompt appended to every Chatllm chat request."
        },
        "chatllm.copilot.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Re-enable the bundled Copilot extension UI surfaces. Recommended to keep disabled while using Chatllm's UI."
        },
        "chatllm.copilot.modelsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Copilot model access via VS Code's Language Model API (vscode.lm). Requires the Copilot model provider to be available."
        }
      }
    },
    "commands": [
      {
        "command": "chatllm.openChat",
        "title": "Open Chatllm Chat",
        "category": "Chatllm",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "chatllm.newChat",
        "title": "New Chat",
        "category": "Chatllm",
        "icon": "$(add)"
      },
      {
        "command": "chatllm.openSettings",
        "title": "Open Chatllm Settings",
        "category": "Chatllm",
        "icon": "$(gear)"
      },
      {
        "command": "chatllm.openPipeline",
        "title": "Open Chatllm Pipeline",
        "category": "Chatllm",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "chatllm.scaffoldFeature",
        "title": "Scaffold Spec Feature",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.setActiveFeature",
        "title": "Set Active Spec Feature",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.openTask",
        "title": "Open Task Contract",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.runTask",
        "title": "Run Task",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.markTaskReady",
        "title": "Mark Task Ready",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.dispatchFeature",
        "title": "Dispatch Feature Tasks",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.regenerateTasksIndex",
        "title": "Regenerate Tasks Index",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.cancelRun",
        "title": "Cancel Active Run",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.refreshSpecs",
        "title": "Refresh Specs",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.refreshTasks",
        "title": "Refresh Tasks",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.refreshRuns",
        "title": "Refresh Runs",
        "category": "Chatllm"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chatllm",
          "title": "Chatllm",
          "icon": "resources/chatllm.svg"
        }
      ],
      "secondarySidebar": [
        {
          "id": "chatllm-chat",
          "title": "Chatllm",
          "icon": "resources/chatllm.svg"
        }
      ]
    },
    "views": {
      "chatllm-chat": [
        {
          "type": "webview",
          "id": "chatllm.chat",
          "name": "Chat",
          "icon": "resources/chatllm.svg",
          "contextualTitle": "Chatllm"
        }
      ],
      "chatllm": [
        {
          "type": "webview",
          "id": "chatllm.pipeline",
          "name": "Pipeline",
          "icon": "resources/chatllm.svg",
          "contextualTitle": "Chatllm"
        },
        {
          "id": "chatllm.specs",
          "name": "Specs"
        },
        {
          "id": "chatllm.tasks",
          "name": "Tasks"
        },
        {
          "id": "chatllm.runs",
          "name": "Agent Runs"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "chatllm.openChat"
        },
        {
          "command": "chatllm.newChat"
        },
        {
          "command": "chatllm.openSettings"
        },
        {
          "command": "chatllm.openPipeline"
        },
        {
          "command": "chatllm.scaffoldFeature"
        },
        {
          "command": "chatllm.dispatchFeature"
        }
      ],
      "view/title": [
        {
          "command": "chatllm.newChat",
          "when": "view == chatllm.chat",
          "group": "navigation@1"
        },
        {
          "command": "chatllm.openSettings",
          "when": "view == chatllm.chat",
          "group": "navigation@2"
        },
        {
          "command": "chatllm.openPipeline",
          "when": "view == chatllm.chat",
          "group": "navigation@3"
        },
        {
          "command": "chatllm.refreshSpecs",
          "when": "view == chatllm.specs",
          "group": "navigation"
        },
        {
          "command": "chatllm.scaffoldFeature",
          "when": "view == chatllm.specs",
          "group": "navigation"
        },
        {
          "command": "chatllm.refreshTasks",
          "when": "view == chatllm.tasks",
          "group": "navigation"
        },
        {
          "command": "chatllm.dispatchFeature",
          "when": "view == chatllm.tasks",
          "group": "navigation"
        },
        {
          "command": "chatllm.refreshRuns",
          "when": "view == chatllm.runs",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "chatllm.openTask",
          "when": "view == chatllm.tasks && viewItem == task",
          "group": "navigation"
        },
        {
          "command": "chatllm.runTask",
          "when": "view == chatllm.tasks && viewItem == task",
          "group": "inline"
        },
        {
          "command": "chatllm.markTaskReady",
          "when": "view == chatllm.tasks && viewItem == task",
          "group": "inline"
        },
        {
          "command": "chatllm.setActiveFeature",
          "when": "view == chatllm.specs && viewItem == feature",
          "group": "inline"
        }
      ]
    }
  },
  "dependencies": {
    "cytoscape": "^3.30.0",
    "cytoscape-dagre": "^2.5.0",
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.90.0",
    "@types/cytoscape": "^3.21.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
