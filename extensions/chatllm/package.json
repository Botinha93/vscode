{
  "name": "chatllm",
  "displayName": "Chatllm",
  "description": "Chatllm integration for the bundled VS Code workspace.",
  "version": "0.2.0",
  "publisher": "chatllm",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:chatllm.specs"
  ],
  "main": "./extension.js",
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch"
  },
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "chatllm.chatllm",
        "name": "chatllm",
        "fullName": "Chatllm",
        "description": "Chat with Chatllm — guided specs, design, tasks, and agent dispatch.",
        "isSticky": true,
        "commands": [
          {
            "name": "spec",
            "description": "Create or refine feature requirements (EARS-style)"
          },
          {
            "name": "design",
            "description": "Draft design.md from requirements"
          },
          {
            "name": "tasks",
            "description": "Generate task contracts from requirements and design"
          },
          {
            "name": "dispatch",
            "description": "Dispatch the task graph to agents in topological order"
          },
          {
            "name": "run",
            "description": "Run a single task by id (e.g. T-003)"
          },
          {
            "name": "status",
            "description": "Show spec and task status for the active feature"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "chatllm.openChat",
        "title": "Open Chatllm Chat",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.openPanel",
        "title": "Open Chatllm Panel (Legacy)",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.refreshPanel",
        "title": "Refresh Chatllm Panel",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.scaffoldFeature",
        "title": "Scaffold Spec Feature",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.setActiveFeature",
        "title": "Set Active Spec Feature",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.openTask",
        "title": "Open Task Contract",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.runTask",
        "title": "Run Task",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.markTaskReady",
        "title": "Mark Task Ready",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.dispatchFeature",
        "title": "Dispatch Feature Tasks",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.regenerateTasksIndex",
        "title": "Regenerate Tasks Index",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.cancelRun",
        "title": "Cancel Active Run",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.refreshSpecs",
        "title": "Refresh Specs",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.refreshTasks",
        "title": "Refresh Tasks",
        "category": "Chatllm"
      },
      {
        "command": "chatllm.refreshRuns",
        "title": "Refresh Runs",
        "category": "Chatllm"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chatllm",
          "title": "Chatllm",
          "icon": "resources/chatllm.svg"
        }
      ]
    },
    "views": {
      "chatllm": [
        {
          "id": "chatllm.specs",
          "name": "Specs"
        },
        {
          "id": "chatllm.tasks",
          "name": "Tasks"
        },
        {
          "id": "chatllm.runs",
          "name": "Agent Runs"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "chatllm.openChat"
        },
        {
          "command": "chatllm.scaffoldFeature"
        },
        {
          "command": "chatllm.dispatchFeature"
        }
      ],
      "view/title": [
        {
          "command": "chatllm.refreshSpecs",
          "when": "view == chatllm.specs",
          "group": "navigation"
        },
        {
          "command": "chatllm.scaffoldFeature",
          "when": "view == chatllm.specs",
          "group": "navigation"
        },
        {
          "command": "chatllm.refreshTasks",
          "when": "view == chatllm.tasks",
          "group": "navigation"
        },
        {
          "command": "chatllm.dispatchFeature",
          "when": "view == chatllm.tasks",
          "group": "navigation"
        },
        {
          "command": "chatllm.refreshRuns",
          "when": "view == chatllm.runs",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "chatllm.openTask",
          "when": "view == chatllm.tasks && viewItem == task",
          "group": "navigation"
        },
        {
          "command": "chatllm.runTask",
          "when": "view == chatllm.tasks && viewItem == task",
          "group": "inline"
        },
        {
          "command": "chatllm.markTaskReady",
          "when": "view == chatllm.tasks && viewItem == task",
          "group": "inline"
        },
        {
          "command": "chatllm.setActiveFeature",
          "when": "view == chatllm.specs && viewItem == feature",
          "group": "inline"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
